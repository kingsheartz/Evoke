APP_NAME=Evoke
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — PostgreSQL (default, required for AI/RAG vector search)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=evoke
DB_USERNAME=evoke
DB_PASSWORD=evoke_secret

# Database — MySQL / MariaDB (XAMPP, optional; AI vector search not available)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=evoke
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MAIL_MAILER=resend
RESEND_API_KEY=

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

RAZORPAY_KEY=
RAZORPAY_SECRET=

MSG91_AUTH_KEY=
MSG91_SENDER_ID=

AI_SERVICE_URL=http://localhost:8001

# OpenAPI / Swagger UI (Scramble) — available when APP_DEBUG=true or APP_ENV=local
API_VERSION=v1
# SCRAMBLE_CACHE_STORE=file
