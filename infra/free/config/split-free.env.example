# Split free-tier reference — Vercel + Render + Neon
# Set these in each platform's dashboard (not committed).

# ── Vercel (frontend/) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://evoke-api.onrender.com/api/v1
NEXT_PUBLIC_APP_NAME=Evoke

# ── Render (backend web service) ───────────────────────────────────────────────
APP_NAME=Evoke
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate_show
APP_URL=https://evoke-api.onrender.com
APP_TIMEZONE=Asia/Kolkata

FRONTEND_URL=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

RUN_MIGRATIONS=true

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

DB_CONNECTION=pgsql
DB_HOST=ep-xxxx.region.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=from-neon-dashboard

# Optional — add when testing those features
# RESEND_API_KEY=
# RAZORPAY_KEY=
# RAZORPAY_SECRET=
