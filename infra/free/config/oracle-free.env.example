# Oracle Cloud Always Free — compose shell env
# Copy: cp infra/free/config/oracle-free.env.example /opt/evoke/.env.production
# Usage: set -a && source .env.production && set +a

# Public URL — use your domain or http://YOUR_VM_IP:8080 for first test
NEXT_PUBLIC_API_URL=http://YOUR_VM_IP:8080/api/v1
NEXT_PUBLIC_APP_NAME=Evoke

# Database (MySQL in compose)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=evoke
DB_USERNAME=evoke
DB_PASSWORD=change-me-strong-password

COMPOSE_PROJECT_NAME=evoke
