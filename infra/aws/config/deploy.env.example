# Evoke AWS deploy configuration — copy to deploy.env on the EC2 host.
# All public endpoints are configurable here and in GitHub / CodeBuild env.

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
ECR_REGISTRY=123456789012.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=latest

# ── Public URLs (used by browser + Laravel) ──────────────────────────────────
# Single-host (nginx proxy): set both to https://yourdomain.com
# Split API subdomain: APP_URL=https://api.yourdomain.com, FRONTEND_URL=https://yourdomain.com
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_APP_NAME=Evoke

# HTTP port exposed on EC2 security group (443 via ALB/Caddy is outside this file)
HTTP_PORT=80

# ── Laravel / database (MySQL recommended on t3.micro free tier) ───────────────
APP_NAME=Evoke
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_TIMEZONE=Asia/Kolkata

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=evoke
DB_USERNAME=evoke
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-root-password

REDIS_HOST=redis
REDIS_PORT=6379
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Comma-separated hosts for Sanctum cookie auth (no scheme, no port for 443)
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
SESSION_DOMAIN=.yourdomain.com

# ── Optional integrations ────────────────────────────────────────────────────
RAZORPAY_KEY=
RAZORPAY_SECRET=
RESEND_API_KEY=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Leave blank to disable AI on small instances
AI_SERVICE_URL=

# ── Deploy behaviour ───────────────────────────────────────────────────────────
RUN_MIGRATIONS=true
SEED_DEMO=true
COMPOSE_FILE=infra/aws/docker-compose.aws.yml

# ── Media storage ──────────────────────────────────────────────────────────────
# Local disk on EC2 (default): FILESYSTEM_DISK=public — served via nginx /storage/
# S3 (recommended for production): FILESYSTEM_DISK=s3 + bucket vars below
FILESYSTEM_DISK=public
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# AWS_BUCKET=evoke-media-prod
# Public object URL prefix (S3 bucket URL or CloudFront distribution)
# AWS_URL=https://evoke-media-prod.s3.ap-south-1.amazonaws.com
# NEXT_PUBLIC_MEDIA_BASE_URL=https://evoke-media-prod.s3.ap-south-1.amazonaws.com
