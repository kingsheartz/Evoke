# VPS production env — source before docker compose on Option A
# Copy: cp infra/vps/config/production.env.example /opt/evoke/.env.production
# Usage: set -a && source .env.production && set +a

# ── Public URLs (must match backend/.env and DNS) ─────────────────────────────
# Single domain:
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_APP_NAME=Evoke

# Build-time args for frontend/Dockerfile.prod (read by docker-compose.prod.yml)
# Split API subdomain example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# ── Compose / database profile ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=evoke
DB_USERNAME=evoke
DB_PASSWORD=change-me-strong-password

# Optional: override compose project name
# COMPOSE_PROJECT_NAME=evoke
